    {
      "name": "Create",
      "item": [
        {
          "name": "Create - Success",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('taskId', String(body.id));",
                  "",
                  "pm.test('Response contains created task', function () {",
                  "  pm.expect(body).to.have.property('id');",
                  "  pm.expect(body.titulo).to.include('Tarea de prueba');",
                  "  pm.expect(body.prioridad).to.eql(2);",
                  "  pm.expect(body.completada).to.eql(false);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Tarea de prueba {{$timestamp}}\",\n  \"prioridad\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/tasks",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "tasks"
              ]
            },
            "description": "Crea una tarea valida y guarda el id en la variable de coleccion taskId."
          },
          "response": []
        },
