  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) {",
          "  pm.collectionVariables.set('baseUrl', 'http://localhost:3000');",
          "}",
          "if (!pm.collectionVariables.get('missingId')) {",
          "  pm.collectionVariables.set('missingId', '999999999');",
          "}",
          "if (!pm.collectionVariables.get('invalidId')) {",
          "  pm.collectionVariables.set('invalidId', 'abc');",
          "}"
        ]
      }
    }
  ],
